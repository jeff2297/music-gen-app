# Mubert API (https://mubert.com/)
MUBERT_API_KEY=your_mubert_api_key_here
MUBERT_API_URL=https://api.mubert.ai

# Replicate API (https://replicate.com/)
REPLICATE_API_TOKEN=your_replicate_token_here

# OpenAI API (https://openai.com/)
OPENAI_API_KEY=your_openai_key_here

# Meta MusicGen (Local/Open Source - No key needed)
USE_META_MUSICGEN=true

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Settings
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# File Upload
MAX_FILE_SIZE=104857600
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/mp4,audio/flac,audio/ogg
